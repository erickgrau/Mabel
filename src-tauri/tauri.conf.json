{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mabel",
  "version": "1.1.2",
  "identifier": "com.mabel.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mabel",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost https://api.groq.com https://huggingface.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Chibitek Labs",
    "copyright": "Copyright (c) 2026 Chibitek Labs. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Privacy-first dictation for macOS.",
    "longDescription": "Mabel is a privacy-first macOS dictation app. Audio is transcribed on-device and deleted immediately. Transcripts are never logged. No telemetry.",
    "externalBin": ["binaries/whisper-cpp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: Erick Grau (DF9FB764AR)",
      "providerShortName": "DF9FB764AR",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "frameworks": [
        "dylibs/libwhisper.1.dylib",
        "dylibs/libggml.0.dylib",
        "dylibs/libggml-base.0.dylib",
        "dylibs/libggml-cpu.0.dylib",
        "dylibs/libggml-blas.0.dylib",
        "dylibs/libggml-metal.0.dylib"
      ]
    }
  }
}
