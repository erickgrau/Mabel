{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main", "overlay", "companion"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "global-shortcut:default",
    "shell:allow-open",
    "autostart:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/whisper-cpp",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
